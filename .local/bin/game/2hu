#!/bin/sh

# Small script for launching Touhou games. Used in the dmenugame script. Requires proton-caller.

export LANG=ja_JP.UTF-8
export pfx=~/.local/share/wineprefixes/touhou
#export WINEPREFIX=~/.local/share/wineprefixes/touhou/pfx
export STEAM_COMPAT_DATA_PATH=$pfx
export STEAM_COMPAT_CLIENT_INSTALL_PATH=$pfx

cd $pfx/pfx/drive_c/2hu/th$1
#~/.steam/steam/steamapps/common/Proton\ 6.3/proton run Touhou$1.lnk
proton-call --log -r Touhou$1.lnk
