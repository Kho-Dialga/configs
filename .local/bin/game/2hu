#!/bin/sh

# Small script for launching Touhou games. Used in the dmenugame script. Requires proton-caller.

export LANG=en_US.UTF-8
export pfx="/media/dialga/wineprefixes/2hu"
export WINEPREFIX=/media/dialga/wineprefixes/touhou/pfx
export STEAM_COMPAT_DATA_PATH=$pfx
export STEAM_COMPAT_CLIENT_INSTALL_PATH=$pfx

cd "$pfx"/pfx/drive_c/2hu/th$1
pwd
#~/.steam/steam/steamapps/common/Proton\ 6.3/proton run ../../thcrap/thcrap_loader.exe C:/2hu/th$1/th$1.exe en.js
proton-call -r ../../thcrap/thcrap_loader.exe $pfx/pfx/drive_c/2hu/th$1/th$1.exe en.js
